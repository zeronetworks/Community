// Copyright 2026 Zero Networks. All rights reserved.
//
// -- Title         : ZN - SMB Share Fanout
// -- Description   : Detects a single internal source connecting to 5+ distinct SMB/NetBIOS
// --                 destinations in a 1-hour aggregation window.
// -- Version       : 1.0.0
// -- Last modified : 2026-05-03
// -- Author        : Zero Networks
// -- MITRE ATT&CK  : TA0040, T1021.002 (SMB/Windows Admin Shares), T1083
// -- Severity      : HIGH
// -- Log type      : ZN_NETWORK

rule zn_smb_share_fanout {
  meta:
    author              = "Zero Networks"
    description         = "Single source connecting to 5+ distinct SMB/NetBIOS destinations in 1h."
    severity            = "HIGH"
    priority            = "HIGH"
    mitre_attack_tactic = "TA0040"
    mitre_attack_technique = "T1021.002"
    version             = "1.0.0"
    last_modified       = "2026-05-03"

  events:
    $e.metadata.log_type = "ZN_NETWORK"
    $e.additional.fields["TrafficType"] = "Internal"

    // SMB ports: 445 (SMB) and 139 (NetBIOS)
    $e.target.port = 445 or $e.target.port = 139

    $src_id = $e.principal.asset.asset_id
    $dst_id = $e.target.asset.asset_id
    $src_id != ""
    $dst_id != ""

  match:
    $src_id over 1h

  outcome:
    $distinct_share_count = count_distinct($dst_id)
    $src_fqdn             = $e.principal.hostname
    $src_ip               = $e.principal.ip
    $src_user             = $e.principal.user.userid
    $src_process          = $e.principal.process.file.full_path
    $conn_statuses        = array_distinct($e.additional.fields["ConnectionStatus"])

  condition:
    $e and $distinct_share_count >= 5
}

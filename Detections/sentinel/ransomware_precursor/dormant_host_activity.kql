// -- Title         : ZN - Dormant Host Reactivation
// -- Description   : Detects an internal asset resuming network activity after 30+ days of
// --                 complete silence. Dormant hosts that suddenly initiate connections may
// --                 indicate compromised or forgotten assets being leveraged by attackers.
// -- Version       : 1.0.0
// -- Last modified : 2026-05-03
// -- Author        : Zero Networks
// -- MITRE ATT&CK  : T1078 (Valid Accounts), T1021 (Remote Services), TA0011 (Command and Control)
// -- Severity      : Medium
// -- Data source   : ZNNetworkActivity_CL
// -- Notes         : Requires 45+ days of data in the table. Assets with no prior history
// --                 (brand-new assets) are suppressed - this rule targets known assets only.

let _dormancyDays  = 30;   // days of silence that defines a dormant host
let _historyWindow = 45;   // total lookback window to establish "known asset" status

// Assets seen in the [now-45d, now-30d] window = known to the environment
let KnownAssets = materialize(
    ZNNetworkActivity_CL
    | where TimeGenerated between (
        ago(totimespan(strcat(tostring(_historyWindow), "d")))
        ..
        ago(totimespan(strcat(tostring(_dormancyDays), "d"))))
    | where TrafficType_s == "Internal"
    | where isnotempty(Src_AssetID_s)
    | summarize LastSeenBefore = max(TimeGenerated) by Src_AssetID_s
);

// Assets seen in the [now-30d, now-1h] window = have NOT been dormant
let ActiveDuringDormancy = materialize(
    ZNNetworkActivity_CL
    | where TimeGenerated between (
        ago(totimespan(strcat(tostring(_dormancyDays), "d")))
        ..
        ago(1h))
    | where TrafficType_s == "Internal"
    | where isnotempty(Src_AssetID_s)
    | summarize by Src_AssetID_s
);

// Dormant = known but silent for _dormancyDays
let DormantAssets = KnownAssets
    | join kind=leftanti ActiveDuringDormancy on Src_AssetID_s;

// Detection: dormant asset now active
ZNNetworkActivity_CL
| where TimeGenerated >= ago(1h)
| where TrafficType_s == "Internal"
| where isnotempty(Src_AssetID_s)
| join kind=inner DormantAssets on Src_AssetID_s
| extend AlertName = strcat(
    "Dormant host reactivated: ",
    iff(isnotempty(Src_Fqdn_s), Src_Fqdn_s, Src_IP_s))
| project
    TimeGenerated,
    AlertName,
    AlertSeverity       = "Medium",
    LastSeenBefore,
    SrcAssetID          = Src_AssetID_s,
    SrcFqdn             = Src_Fqdn_s,
    SrcIP               = Src_IP_s,
    SrcAssetType        = Src_AssetType_s,
    SrcSegState         = Src_AssetNetworkSegmentationState_s,
    DstAssetID          = Dst_AssetID_s,
    DstFqdn             = Dst_Fqdn_s,
    DstIP               = Dst_IP_s,
    DstPort             = Dst_Port_d,
    ConnectionStatus    = ConnectionStatus_s
| sort by TimeGenerated desc

// -- Title         : ZN - Mass Write to Shares (New SMB Source)
// -- Description   : Fires when an internal source initiates SMB connections for the first
// --                 time - not seen in the 14-day baseline. Covers all asset types.
// -- Version       : 1.0.0
// -- Last modified : 2026-05-03
// -- Author        : Zero Networks
// -- MITRE ATT&CK  : T1021.002 (SMB/Windows Admin Shares), T1486 (Data Encrypted for Impact)
// -- Severity      : High (established), Medium (blocked/requested), Low (blocked_at_source)
// -- Index         : logs-zn.network-*
// --
// -- DEPLOYMENT: Use the "new_terms" rule type in Kibana Detection Engine.
// --
// -- new_terms rule configuration:
// --   rule_type          : new_terms
// --   index              : logs-zn.network-*
// --   new_terms_fields   : ["Src.AssetID"]
// --   history_window_start: now-14d
// --   interval           : 1h
// --   from               : now-65m
// --   query (KQL)        : see below
// --
// -- KQL filter:
//
//    TrafficType: "Internal"
//    AND Dst.Port: (445 OR 139)
//    AND Src.AssetID: *
//    AND Dst.AssetID: *
//
// -- EQL query (custom_query fallback):

any where
    event.dataset == "zn.network"
    and TrafficType == "Internal"
    and Dst.Port in (445, 139)
    and Src.AssetID != null and Src.AssetID != ""
    and Dst.AssetID != null and Dst.AssetID != ""

// -- Field reference:
// --   Src.AssetID    : source asset - new_terms tracks first-seen values
// --   Dst.Port       : 445 (SMB), 139 (NetBIOS)
// --   ConnectionStatus: "established" | "blocked" | "requested" | "blocked_at_source"
// --   Src.AssetType  : all types covered (workstation, server, OT)

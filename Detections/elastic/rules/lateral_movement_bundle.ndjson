{"id":"zn-lm-001","name":"ZN - New Internal Asset Pair","description":"Detects first-ever communication between two internal ZN-managed assets. Deploy as new_terms rule for true first-seen semantics over a 14-day history window.","risk_score":73,"severity":"high","type":"new_terms","new_terms_fields":["Src.AssetID","Dst.AssetID"],"history_window_start":"now-14d","query":"TrafficType: \"Internal\" AND Src.AssetID: * AND Dst.AssetID: *","index":["logs-zn.network-*"],"interval":"1h","from":"now-65m","language":"kuery","rule_id":"zn-lm-001","version":1,"author":["Zero Networks"],"tags":["Zero Networks","Lateral Movement","T1021"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0008","name":"Lateral Movement","reference":"https://attack.mitre.org/tactics/TA0008/"},"technique":[{"id":"T1021","name":"Remote Services","reference":"https://attack.mitre.org/techniques/T1021/"}]}],"enabled":false,"created_at":"2026-04-22T00:00:00.000Z","updated_at":"2026-04-22T00:00:00.000Z"}
{"id":"zn-lm-002","name":"ZN - Internal Port Fanout","description":"Detects a single internal source asset connecting to 20+ distinct destination assets within 10 minutes. Indicates lateral movement scanning or ransomware propagation.","risk_score":73,"severity":"high","type":"threshold","query":"TrafficType: \"Internal\" AND Src.AssetID: * AND Dst.AssetID: * AND NOT Src.AssetType: \"Domain Controller\"","threshold":{"field":["Src.AssetID"],"value":1,"cardinality":[{"field":"Dst.AssetID","value":20}]},"index":["logs-zn.network-*"],"interval":"5m","from":"now-10m","language":"kuery","rule_id":"zn-lm-002","version":1,"author":["Zero Networks"],"tags":["Zero Networks","Lateral Movement","T1046","Discovery"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0007","name":"Discovery","reference":"https://attack.mitre.org/tactics/TA0007/"},"technique":[{"id":"T1046","name":"Network Service Discovery","reference":"https://attack.mitre.org/techniques/T1046/"}]}],"enabled":false,"created_at":"2026-04-22T00:00:00.000Z","updated_at":"2026-04-22T00:00:00.000Z"}
{"id":"zn-lm-003","name":"ZN - First SMB / RDP / WinRM from Workstation","description":"Fires the first time a workstation initiates SMB (445/139), RDP (3389), WinRM (5985/5986), SSH (22), RPC (135), or LDAP (389/636) - not seen in 14-day history.","risk_score":73,"severity":"high","type":"new_terms","new_terms_fields":["Src.AssetID","Dst.Port"],"history_window_start":"now-14d","query":"TrafficType: \"Internal\" AND Src.AssetType: \"Workstation\" AND Src.AssetID: * AND Dst.Port: (22 OR 135 OR 139 OR 389 OR 445 OR 636 OR 3389 OR 5985 OR 5986)","index":["logs-zn.network-*"],"interval":"1h","from":"now-65m","language":"kuery","rule_id":"zn-lm-003","version":1,"author":["Zero Networks"],"tags":["Zero Networks","Lateral Movement","SMB","RDP","WinRM","T1021.001","T1021.002","T1021.006"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0008","name":"Lateral Movement","reference":"https://attack.mitre.org/tactics/TA0008/"},"technique":[{"id":"T1021","name":"Remote Services","reference":"https://attack.mitre.org/techniques/T1021/","subtechnique":[{"id":"T1021.001","name":"Remote Desktop Protocol","reference":"https://attack.mitre.org/techniques/T1021/001/"},{"id":"T1021.002","name":"SMB/Windows Admin Shares","reference":"https://attack.mitre.org/techniques/T1021/002/"},{"id":"T1021.006","name":"Windows Remote Management","reference":"https://attack.mitre.org/techniques/T1021/006/"}]}]}],"enabled":false,"created_at":"2026-04-22T00:00:00.000Z","updated_at":"2026-04-22T00:00:00.000Z"}
{"id":"zn-lm-004","name":"ZN - OT/IT Boundary Crossing","description":"Detects communication crossing the OT/IT boundary - one side has a populated OTSwitchID and the other does not. Both OT->IT and IT->OT directions are alerted. No baseline required.","risk_score":85,"severity":"high","type":"query","query":"event.dataset: \"zn.network\" AND TrafficType: \"Internal\" AND ((Src.OTSwitchID: * AND NOT Dst.OTSwitchID: *) OR (Dst.OTSwitchID: * AND NOT Src.OTSwitchID: *))","index":["logs-zn.network-*"],"interval":"5m","from":"now-10m","language":"kuery","rule_id":"zn-lm-004","version":1,"author":["Zero Networks"],"tags":["Zero Networks","OT","ICS","Lateral Movement","T1599","Boundary Bridging"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0005","name":"Defense Evasion","reference":"https://attack.mitre.org/tactics/TA0005/"},"technique":[{"id":"T1599","name":"Network Boundary Bridging","reference":"https://attack.mitre.org/techniques/T1599/"}]}],"enabled":false,"created_at":"2026-04-22T00:00:00.000Z","updated_at":"2026-04-22T00:00:00.000Z"}
{"id":"zn-lm-005","name":"ZN - New RPC Pair (Dangerous Interface)","description":"Fires when a new (src, dst, rpc_operation) triple is observed for a high-risk RPC interface not seen in the 14-day history. Covers drsuapi (DCSync), IWbemServices (WMI), ITaskSchedulerService, svcctl, winreg, samr.","risk_score":85,"severity":"high","type":"new_terms","new_terms_fields":["Src.AssetID","Dst.AssetID","Operation.Name"],"history_window_start":"now-14d","query":"Operation.Name: (\"ITaskSchedulerService\" OR \"IWbemServices\" OR \"winreg\" OR \"drsuapi\" OR \"samr\" OR \"svcctl\") AND Src.AssetID: * AND Dst.AssetID: *","index":["logs-zn.rpc-*"],"interval":"1h","from":"now-65m","language":"kuery","rule_id":"zn-lm-005","version":1,"author":["Zero Networks"],"tags":["Zero Networks","Lateral Movement","RPC","DCSync","WMI","T1047","T1053.005","T1003.006"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0008","name":"Lateral Movement","reference":"https://attack.mitre.org/tactics/TA0008/"},"technique":[{"id":"T1047","name":"Windows Management Instrumentation","reference":"https://attack.mitre.org/techniques/T1047/"},{"id":"T1053","name":"Scheduled Task/Job","reference":"https://attack.mitre.org/techniques/T1053/","subtechnique":[{"id":"T1053.005","name":"Scheduled Task","reference":"https://attack.mitre.org/techniques/T1053/005/"}]},{"id":"T1003","name":"OS Credential Dumping","reference":"https://attack.mitre.org/techniques/T1003/","subtechnique":[{"id":"T1003.006","name":"DCSync","reference":"https://attack.mitre.org/techniques/T1003/006/"}]}]}],"enabled":false,"created_at":"2026-04-22T00:00:00.000Z","updated_at":"2026-04-22T00:00:00.000Z"}
